# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"  # PostgreSQL connection used by Prisma
PRISMA_LOG_QUERIES="false"  # Set to true to log Prisma SQL queries

# Authentication (Google OAuth)
GOOGLE_CLIENT_ID="google_client_id_placeholder"  # Google OAuth client id
GOOGLE_CLIENT_SECRET="google_client_secret_placeholder"  # Google OAuth client secret

# Stripe
STRIPE_SECRET_KEY="sk_live_or_test_placeholder"  # Stripe secret key for server API calls
STRIPE_WEBHOOK_SECRET="whsec_placeholder"  # Stripe webhook signature secret

# Colissimo
COLISSIMO_WS_BASE_URL="https://ws.colissimo.fr"  # Colissimo API base URL
COLISSIMO_WS_API_KEY="colissimo_api_key_placeholder"  # Colissimo API key

# Email
RESEND_API_KEY="re_placeholder"  # Resend API key for sending emails
EMAIL_FROM="no-reply@your-domain.com"  # Sender email address

# Internal jobs
CRON_SECRET="replace_me"  # Secret checked by internal cron endpoint

# NEXTAUTH
NEXTAUTH_SECRET=your-generated-secret-here
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
